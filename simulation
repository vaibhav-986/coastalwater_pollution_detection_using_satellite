    error_map = np.ones((grid_size, grid_size)) * max(0.2, min(5, error))
    # Add spatial variation
    error_map = error_map + 0.5 * np.random.randn(grid_size, grid_size)
    error_map = np.clip(error_map, 0.1, 6)
    errors.append(error_map)

im_error = ax6.imshow(errors[0], cmap='hot', origin='lower', vmin=0, vmax=5)
ax6.set_xlabel('Distance (km)')
ax6.set_ylabel('Distance (km)')
plt.colorbar(im_error, ax=ax6, label='Prediction Error (mg/m³)')


def update_animation6(frame):
