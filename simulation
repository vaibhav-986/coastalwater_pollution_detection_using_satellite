print("\n🎬 Creating Animation 4: Seasonal Water Quality Changes...")

fig4, axes4 = plt.subplots(1, 2, figsize=(12, 5))
fig4.suptitle('🌊 Simulated Seasonal Water Quality Changes', fontsize=14, fontweight='bold')

