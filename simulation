    im_error.set_array(errors[frame])
    current_max = np.max(errors[frame])
    ax6.set_title(f'Prediction Error Map - Iteration {frame + 1}/30\n'
                  f'Max Error: {current_max:.2f} mg/m³ (Reducing Over Time)')
    return im_error


