axes4[0].set_title('Chlorophyll-a Distribution')
axes4[0].set_xlabel('Distance (km)')
axes4[0].set_ylabel('Distance (km)')
plt.colorbar(im_map, ax=axes4[0])

# Second subplot: Time series graph
axes4[1].set_xlim(0, time_steps)
axes4[1].set_ylim(5, 30)
axes4[1].set_xlabel('Month')
axes4[1].set_ylabel('Mean Chlorophyll-a (mg/m³)')
axes4[1].set_title('Time Series Analysis')
axes4[1].grid(alpha=0.3)
line, = axes4[1].plot([], [], 'b-', linewidth=2, label='Mean Chlorophyll')
axes4[1].legend()

mean_values = []


def update_animation4(frame):
    """Update water quality animation"""
    # Update map
    im_map.set_array(chlorophyll_time_series[frame])
    axes4[0].set_title(f'Chlorophyll-a - Month {frame + 1}')

    # Update time series
    mean_val = np.mean(chlorophyll_time_series[frame])
    mean_values.append(mean_val)
    line.set_data(range(len(mean_values)), mean_values)
    axes4[1].relim()
    axes4[1].autoscale_view(scaley=True)

    return im_map, line


ani4 = FuncAnimation(fig4, update_animation4, frames=time_steps, interval=300, repeat=True)
ani4.save(f'{output_dir}/animation_4_seasonal_changes.gif', writer=PillowWriter(fps=3))
print(f"   ✓ Saved: {output_dir}/animation_4_seasonal_changes.gif")
